# Upstream with failover for solar dashboard
upstream solar_dashboard {
    server 10.8.0.2:8080 max_fails=2 fail_timeout=10s;    # Pi 5 - Primary
    server 192.168.6.72:8081 backup;                       # ESP8266 - Backup
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;
    server_name _;
    location / {
        try_files $uri $uri/ =404;
    }
}

server {
    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;
    server_name mercalde-solar.org;

    # Alexa webhook
    location /alexa {
        proxy_pass http://127.0.0.1:5000/alexa;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Solar Dashboard with failover at /dashboard
    location /dashboard {
        proxy_pass http://solar_dashboard/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
        proxy_next_upstream error timeout http_502 http_503 http_504;
    }

    # Dashboard API endpoints
    location /data {
        proxy_pass http://solar_dashboard/data;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /setgen {
        proxy_pass http://solar_dashboard/setgen;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /stopgen {
        proxy_pass http://solar_dashboard/stopgen;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /config {
        proxy_pass http://solar_dashboard/config;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /setmpptmode {
        proxy_pass http://solar_dashboard/setmpptmode;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Register tool endpoints
    location /registers {
        proxy_pass http://solar_dashboard/registers;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /readreg {
        proxy_pass http://solar_dashboard/readreg;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /writereg {
        proxy_pass http://solar_dashboard/writereg;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /readtransfer {
        proxy_pass http://solar_dashboard/readtransfer;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /readags {
        proxy_pass http://solar_dashboard/readags;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /testtelegram {
        proxy_pass http://solar_dashboard/testtelegram;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # InsightLocal - main page
    location / {
        proxy_pass https://10.8.0.2:443;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_ssl_verify off;
    }

    listen [::]:443 ssl ipv6only=on;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/mercalde-solar.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mercalde-solar.org/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = mercalde-solar.org) {
        return 301 https://$host$request_uri;
    }
    listen 80 ;
    listen [::]:80 ;
    server_name mercalde-solar.org;
    return 404;
}

# Direct access to ESP8266 on port 8080 (legacy)
server {
    listen 8080;
    listen [::]:8080;
    server_name _;

    location / {
        proxy_pass http://192.168.6.72:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
    }
}
